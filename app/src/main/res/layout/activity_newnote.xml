<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:padding="12dp">

        <ImageView
            android:id="@+id/backBtn"
            android:src="@android:drawable/ic_media_previous"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentStart="true"
            app:tint="#000000" />

        <TextView
            android:text="New Note"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerInParent="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:layout_alignParentEnd="true"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <ImageView
                android:src="@android:drawable/ic_menu_edit"
                android:layout_marginEnd="16dp"
                android:layout_width="22dp"
                android:layout_height="22dp"
                app:tint="#000000" />

            <ImageView
                android:id="@+id/saveBtn"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_save"
                app:tint="#000000" />
        </LinearLayout>
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:hint="Title"
                android:textColor="#000000"
                android:textColorHint="#888888"
                android:textSize="26sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">
                <TextView android:text="B" android:textStyle="bold" android:textSize="18sp" android:layout_marginEnd="20dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/>
                <TextView android:text="I" android:textStyle="italic" android:textSize="18sp" android:layout_marginEnd="20dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/>
                <TextView android:text="&lt;&gt;" android:textSize="16sp" android:layout_marginEnd="20dp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/>
                <TextView android:text="List" android:textSize="18sp" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#000000"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="#DDDDDD" />

            <EditText
                android:id="@+id/etContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@android:color/transparent"
                android:gravity="top"
                android:hint="Start typing..."
                android:minHeight="200dp"
                android:textColor="#333333"
                android:textColorHint="#888888" />

            <TextView
                android:text="Tags (separated by commas)"
                android:layout_marginTop="20dp"
                android:textColor="#5B5B5B"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <EditText
                android:id="@+id/etTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@android:drawable/editbox_background"
                android:hint="work, important..."
                android:padding="12dp"
                android:textColor="#000000"
                android:textColorHint="#AAAAAA" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>